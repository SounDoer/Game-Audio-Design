---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pages = (await getCollection('resourcePages')).sort(
  (a, b) =>
    ((a.data as { sidebar_position?: number }).sidebar_position ?? 999) -
    ((b.data as { sidebar_position?: number }).sidebar_position ?? 999),
);
if (pages.length === 0) {
  throw new Error('Missing content under docs/Resource');
}

const sections = await Promise.all(
  pages.map(async (entry) => {
    const { Content } = await render(entry);
    return { Content, id: entry.id };
  }),
);
---

<BaseLayout
  title="Resource | Game Audio Design"
  description="游戏音频设计相关资源与外链（持续更新）。"
  path="/resource"
>
  {
    sections.map(({ Content, id }) => (
      <article class="prose" style="margin-bottom:2.5rem" data-entry-id={id}>
        <Content />
      </article>
    ))
  }
</BaseLayout>
