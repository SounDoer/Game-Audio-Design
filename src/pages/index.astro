---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { render } from 'astro:content';

const pages = await getCollection('homePage');
const homeEntry = pages[0];
if (!homeEntry) {
  throw new Error('Missing docs/Home.md');
}
const { Content } = await render(homeEntry);
---

<BaseLayout
  title="Game Audio Design | 目录"
  description="手动维护的文章目录与站点索引。"
  path="/"
>
  <h1>Game Audio Design</h1>
  <article class="prose home-index-content">
    <Content />
  </article>
  <script is:inline>
    (function () {
      var root = document.querySelector('.home-index-content');
      if (!root) return;

      var excluded = new Set(['/resource', '/log', '/rss.xml', '/']);
      var links = root.querySelectorAll('a[href]');
      links.forEach(function (link) {
        var href = link.getAttribute('href');
        if (!href) return;
        if (!href.startsWith('/')) return;
        if (href.startsWith('/#')) return;
        if (excluded.has(href)) return;
        link.setAttribute('target', '_blank');
        link.setAttribute('rel', 'noopener noreferrer');
      });
    })();
  </script>
</BaseLayout>
