---
import { getCollection } from 'astro:content';
import { stat } from 'node:fs/promises';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const course = await getCollection('courseArticles');
const topic = await getCollection('topicArticles');

function stripMd(id: string) {
  return id.replace(/\.mdx?$/, '');
}

function titleOf(entry: (typeof course)[number]) {
  const d = entry.data as Record<string, unknown>;
  const t = typeof d.title === 'string' ? d.title.trim() : '';
  if (t) return t;
  return stripMd(entry.id).split('/').pop() || entry.id;
}

function descriptionOf(entry: (typeof course)[number]) {
  const d = entry.data as Record<string, unknown>;
  const desc = typeof d.description === 'string' ? d.description.trim() : '';
  if (desc) return desc;
  return entry.id;
}

function hrefCourse(entry: (typeof course)[number]) {
  const base = stripMd(entry.id);
  return `/articles/course/${base}`;
}

function hrefTopic(entry: (typeof topic)[number]) {
  const base = stripMd(entry.id);
  return `/articles/topic/${base}`;
}

async function mtimeOf(entryId: string, section: 'Course' | 'Topic') {
  try {
    const fullPath = resolve('docs', section, entryId);
    const s = await stat(fullPath);
    return s.mtime;
  } catch {
    return new Date(0);
  }
}

const courseFiltered = course.filter((e) => {
  if (stripMd(e.id) === 'Course') return false;
  if ((e.data as { slug?: unknown }).slug === '/') return false;
  return true;
});
const courseSorted = [...courseFiltered].sort(
  (a, b) =>
    ((a.data as { sidebar_position?: number }).sidebar_position ?? 999) -
    ((b.data as { sidebar_position?: number }).sidebar_position ?? 999),
);
const topicSorted = [...topic].sort(
  (a, b) =>
    ((a.data as { sidebar_position?: number }).sidebar_position ?? 999) -
    ((b.data as { sidebar_position?: number }).sidebar_position ?? 999),
);

const latestArticles = (
  await Promise.all([
    ...courseFiltered.map(async (entry) => ({
      kind: 'course' as const,
      href: hrefCourse(entry),
      title: titleOf(entry),
      description: descriptionOf(entry),
      updatedAt: await mtimeOf(entry.id, 'Course'),
    })),
    ...topic.map(async (entry) => ({
      kind: 'topic' as const,
      href: hrefTopic(entry),
      title: titleOf(entry),
      description: descriptionOf(entry),
      updatedAt: await mtimeOf(entry.id, 'Topic'),
    })),
  ])
).sort((a, b) => b.updatedAt.getTime() - a.updatedAt.getTime());

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout
  title="Game Audio Design | 目录"
  description="游戏音频设计专题与文章索引。"
  path="/"
>
  <h1>Game Audio Design</h1>
  <p style="color:var(--muted);">
    先看「最新更新」，再按 Course / Topic 继续浏览；Resource 为独立介绍页，见下「其他」。
  </p>

  <section class="index-section">
    <h2>最新更新</h2>
    <ul class="index-list">
      {
        latestArticles.map((e) => (
          <li>
            <span class="badge">{e.kind}</span>
            <a href={e.href}>{e.title}</a>
            <span style="color:var(--muted);font-size:0.85rem;">
              {' '}
              — {e.description}（{dateFormatter.format(e.updatedAt)}）
            </span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="index-section">
    <h2>Course</h2>
    <ul class="index-list">
      {
        courseSorted.map((e) => (
          <li>
            <span class="badge">course</span>
            <a href={hrefCourse(e)}>{titleOf(e)}</a>
            <span style="color:var(--muted);font-size:0.85rem;"> — {descriptionOf(e)}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="index-section">
    <h2>Topic</h2>
    <ul class="index-list">
      {
        topicSorted.map((e) => (
          <li>
            <span class="badge">topic</span>
            <a href={hrefTopic(e)}>{titleOf(e)}</a>
            <span style="color:var(--muted);font-size:0.85rem;"> — {descriptionOf(e)}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="index-section">
    <h2>其他</h2>
    <ul class="index-list">
      <li>
        <a href="/resource">Resource</a>
        <span style="color:var(--muted);font-size:0.85rem;"> — 资源与外链（施工中）</span>
      </li>
      <li>
        <a href="/log">Log</a>
        <span style="color:var(--muted);font-size:0.85rem;"> — 更新与说明</span>
      </li>
      <li>
        <a href="/rss.xml">RSS</a>
      </li>
    </ul>
  </section>
</BaseLayout>
