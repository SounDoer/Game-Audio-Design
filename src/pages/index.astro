---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import {
  displayTitleFromEntry,
  isArticleEntry,
  parseDateOrNull,
  slugFromEntry,
} from '../lib/article-slug';

type HomeItem = {
  slug: string;
  title: string;
  description: string;
  pinned: boolean;
  pinnedOrder: number | null;
  date: Date;
};

const entries = await getCollection('articles');
const allItems: HomeItem[] = entries
  .filter((entry) => isArticleEntry(entry.id))
  .map((entry) => {
    const data = entry.data as Record<string, unknown>;
    const date = parseDateOrNull(data.date);
    if (!date) return null;

    const description = typeof data.description === 'string' ? data.description.trim() : '';
    if (!description) return null;

    const pinned = data.pinned === true;
    const pinnedOrder = typeof data.pinnedOrder === 'number' ? data.pinnedOrder : null;

    return {
      slug: slugFromEntry(entry.id, data),
      title: displayTitleFromEntry(entry.id, entry.body ?? '', data),
      description,
      pinned,
      pinnedOrder,
      date,
    };
  })
  .filter((item): item is HomeItem => item !== null);

const pinnedItems = allItems
  .filter((item) => item.pinned)
  .sort((a, b) => {
    if (a.pinnedOrder !== null && b.pinnedOrder !== null && a.pinnedOrder !== b.pinnedOrder) {
      return a.pinnedOrder - b.pinnedOrder;
    }
    return b.date.getTime() - a.date.getTime();
  })
  .slice(0, 3);

const pinnedSlugSet = new Set(pinnedItems.map((item) => item.slug));
const regularItems = allItems
  .filter((item) => !pinnedSlugSet.has(item.slug))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const orderedItems = [...pinnedItems, ...regularItems];
const hasNewsletter = (import.meta.env.PUBLIC_BUTTONDOWN_USERNAME?.trim() ?? '').length > 0;
---

<BaseLayout
  title="Game Audio Design"
  description="Game Audio Design articles"
  path="/"
>
  <p class="site-identity">
    <span>游戏音频设计 Game Audio Design</span>
    <a href="https://soundoer.com/" target="_blank" rel="noopener noreferrer">SounDoer</a>
  </p>

  <section class="home-index-controls">
    <label class="search-box">
      <span class="search-icon" aria-hidden="true">🔍</span>
      <input
        id="article-search"
        type="search"
        aria-label="Search title or description"
        aria-controls="article-list"
        autocomplete="off"
      />
      <button id="clear-search" type="button" aria-label="Clear search" aria-controls="article-list" hidden>
        ×
      </button>
    </label>
    <p id="article-count" class="article-count" role="status" aria-live="polite" aria-atomic="true">
      {`${orderedItems.length} articles / ${orderedItems.length} matching`}
    </p>
  </section>

  <article class="prose">
    <ul id="article-list" class="article-list">
      {
        orderedItems.map((item) => (
          <li
            class="article-item"
            data-title={item.title.toLowerCase()}
            data-title-original={item.title}
            data-description={item.description.toLowerCase()}
          >
            <a href={`/${item.slug}/`} class="article-link">
              {item.pinned ? <span class="pin-mark">[Pinned] </span> : null}
              <span class="article-title">{item.title}</span>
            </a>
            <p>{item.description}</p>
            <time
              class="article-date"
              datetime={item.date.toISOString().slice(0, 10)}
            >
              {item.date.toISOString().slice(0, 10)}
            </time>
          </li>
        ))
      }
    </ul>
    <p id="empty-result" hidden>No results. <button id="empty-clear" type="button">Clear</button></p>
  </article>

  {hasNewsletter ? <SubscribeForm compact={true} heading="Subscribe" /> : null}
  <script is:inline>
    (function () {
      var input = document.getElementById('article-search');
      var clearBtn = document.getElementById('clear-search');
      var emptyClear = document.getElementById('empty-clear');
      var list = document.getElementById('article-list');
      var items = list ? Array.prototype.slice.call(list.querySelectorAll('.article-item')) : [];
      var count = document.getElementById('article-count');
      var empty = document.getElementById('empty-result');

      if (!input || !list || !count || !empty) return;

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/\"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function highlightText(raw, query) {
        if (!query) return escapeHtml(raw);
        var lowerRaw = raw.toLowerCase();
        var lowerQuery = query.toLowerCase();
        var start = lowerRaw.indexOf(lowerQuery);
        if (start < 0) return escapeHtml(raw);
        var end = start + lowerQuery.length;
        return (
          escapeHtml(raw.slice(0, start)) +
          '<mark>' +
          escapeHtml(raw.slice(start, end)) +
          '</mark>' +
          escapeHtml(raw.slice(end))
        );
      }

      function updateHighlight(query) {
        items.forEach(function (item) {
          var titleNode = item.querySelector('.article-title');
          if (!titleNode) return;
          var rawTitle = item.getAttribute('data-title-original') || titleNode.textContent || '';
          titleNode.innerHTML = highlightText(rawTitle, query);
        });
      }

      function normalize(value) {
        return String(value || '').toLowerCase();
      }

      function applyFilter() {
        var query = normalize(input.value).trim();
        var matched = 0;
        items.forEach(function (item) {
          var title = item.getAttribute('data-title') || '';
          var description = item.getAttribute('data-description') || '';
          var visible = !query || title.indexOf(query) >= 0 || description.indexOf(query) >= 0;
          item.hidden = !visible;
          if (visible) matched += 1;
        });

        count.textContent = items.length + ' articles / ' + matched + ' matching';
        updateHighlight(query);
        empty.hidden = matched !== 0;
        if (clearBtn) {
          clearBtn.hidden = !query;
        }
      }

      function clearSearch() {
        input.value = '';
        applyFilter();
        input.focus();
      }

      var debounceTimer = null;
      input.addEventListener('input', function () {
        if (debounceTimer) {
          clearTimeout(debounceTimer);
        }
        debounceTimer = setTimeout(function () {
          applyFilter();
        }, 80);
      });
      input.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          event.preventDefault();
          if (input.value.trim()) {
            clearSearch();
          } else {
            input.blur();
          }
        }
      });

      if (clearBtn) {
        clearBtn.addEventListener('click', clearSearch);
      }
      if (emptyClear) {
        emptyClear.addEventListener('click', clearSearch);
      }

      document.addEventListener('keydown', function (event) {
        var active = document.activeElement;
        var tag = active && active.tagName ? active.tagName.toLowerCase() : '';
        if (event.key === '/' && tag !== 'input' && tag !== 'textarea') {
          event.preventDefault();
          input.focus();
        }
      });

      applyFilter();
    })();
  </script>
</BaseLayout>
