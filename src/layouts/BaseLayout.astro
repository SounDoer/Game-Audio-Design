---
import '../styles/global.css';

interface Props {
  title: string;
  /** optional: social share title (defaults to title) */
  ogTitle?: string;
  description?: string;
  /** pathname starting with /, no trailing slash */
  path: string;
  /** article pages use 'article', index/log pages use 'website' */
  ogType?: 'website' | 'article';
  /** optional: per-page OG image (absolute URL or site-relative path) */
  ogImage?: string;
}

const { title, ogTitle, description, path, ogType = 'website', ogImage } = Astro.props;
const canonical = new URL(path, Astro.site).href;
const desc =
  description?.trim() ||
  'Game Audio Design — In-depth articles on game audio design.';
const resolvedOgTitle = typeof ogTitle === 'string' && ogTitle.trim() ? ogTitle.trim() : title;
const defaultOgImagePath = '/img/GAD_Logo_Black.png';
const resolvedOgImage = (() => {
  if (typeof ogImage === 'string' && ogImage.trim()) {
    return new URL(ogImage.trim(), Astro.site).href;
  }
  return new URL(defaultOgImagePath, Astro.site).href;
})();
const resolvedOgImageType = (() => {
  const lower = resolvedOgImage.toLowerCase();
  if (lower.endsWith('.png')) return 'image/png';
  if (lower.endsWith('.webp')) return 'image/webp';
  if (lower.endsWith('.gif')) return 'image/gif';
  return 'image/jpeg';
})();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/img/GAD_Logo.svg" type="image/svg+xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:secure_url" content={resolvedOgImage} />
    <meta property="og:image:type" content={resolvedOgImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Game Audio Design" />
    <meta property="og:locale" content="zh_CN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={resolvedOgImage} />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
