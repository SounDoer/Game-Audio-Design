---
import QRCode from 'qrcode';
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import SubscribeForm from '../components/SubscribeForm.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { displayTitleFromEntry } from '../lib/article-slug';

type ArticleCollection = 'articles';

interface Props {
  entry: CollectionEntry<ArticleCollection>;
  path: string;
  /** display label, e.g. course / topic */
  sectionLabel: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { entry, path, headings = [] } = Astro.props;

const data = entry.data as Record<string, unknown>;
const title = displayTitleFromEntry(entry.id, entry.body ?? '', data).trim() || 'Untitled';
const description =
  typeof data.description === 'string' ? data.description : undefined;
const ogImage = (() => {
  const candidates = ['ogImage', 'og_image', 'image', 'cover', 'thumbnail'];
  for (const key of candidates) {
    const value = data[key];
    if (typeof value === 'string' && value.trim()) {
      return value.trim();
    }
  }
  return undefined;
})();

const canonical = new URL(path, Astro.site).href;
let qrDataUrl = '';
const hasNewsletter = (import.meta.env.PUBLIC_BUTTONDOWN_USERNAME?.trim() ?? '').length > 0;
try {
  qrDataUrl = await QRCode.toDataURL(canonical, { margin: 1, width: 180 });
} catch {
  qrDataUrl = '';
}
---

<BaseLayout
  title={`${title} | Game Audio Design`}
  ogTitle={title}
  description={description}
  path={path}
  ogType="article"
  ogImage={ogImage}
>
  <article class="prose">
    <slot />
  </article>
  <TableOfContents headings={headings} />

  {hasNewsletter ? <SubscribeForm compact={true} heading="Subscribe for new articles" /> : null}
  <div class="fixed-actions">
    <a href="/" class="back-home-link">--> Home</a>
    {qrDataUrl ? (
      <div class="share-wrap">
        <div class="share-popover" id="share-popover" hidden>
          <img src={qrDataUrl} width="140" height="140" alt="QR code for this page" />
          <p class="share-popover-label">Scan to share on WeChat</p>
        </div>
        <button class="share-btn" aria-expanded="false" aria-controls="share-popover">--> Share</button>
      </div>
    ) : null}
  </div>
  <script>
    const btn = document.querySelector<HTMLButtonElement>('.share-btn');
    const popover = document.getElementById('share-popover');
    if (btn && popover) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        popover.hidden = expanded;
      });
      document.addEventListener('click', () => {
        btn.setAttribute('aria-expanded', 'false');
        popover.hidden = true;
      });
    }
  </script>
</BaseLayout>
