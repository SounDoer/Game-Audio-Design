---
import QRCode from 'qrcode';
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import SubscribeForm from '../components/SubscribeForm.astro';

type ArticleCollection = 'articles';

interface Props {
  entry: CollectionEntry<ArticleCollection>;
  path: string;
  /** 用于展示，如 course / topic */
  sectionLabel: string;
}

const { entry, path, sectionLabel } = Astro.props;

const data = entry.data as Record<string, unknown>;
const rawTitle = typeof data.title === 'string' ? data.title : undefined;
const title = rawTitle?.trim() || entry.id.replace(/\.mdx?$/, '').split('/').pop() || '未命名';
const description =
  typeof data.description === 'string' ? data.description : undefined;
const ogImage = (() => {
  const candidates = ['ogImage', 'og_image', 'image', 'cover', 'thumbnail'];
  for (const key of candidates) {
    const value = data[key];
    if (typeof value === 'string' && value.trim()) {
      return value.trim();
    }
  }
  return undefined;
})();

const canonical = new URL(path, Astro.site).href.replace(/\/$/, '');
let qrDataUrl = '';
const hasNewsletter = (import.meta.env.PUBLIC_BUTTONDOWN_USERNAME?.trim() ?? '').length > 0;
try {
  qrDataUrl = await QRCode.toDataURL(canonical, { margin: 1, width: 180 });
} catch {
  qrDataUrl = '';
}
---

<BaseLayout
  title={`${title} | Game Audio Design`}
  description={description}
  path={path}
  ogType="article"
  ogImage={ogImage}
>
  <article class="prose">
    <slot />
  </article>

  <section class="share-box" aria-labelledby="share-heading">
    <h2 id="share-heading">分享</h2>
    <div class="share-row">
      {
        qrDataUrl ? (
          <div class="share-qr">
            <img src={qrDataUrl} width="180" height="180" alt="当前页链接二维码" />
            <span>微信扫码分享</span>
          </div>
        ) : null
      }
    </div>
  </section>
  {hasNewsletter ? <SubscribeForm compact={true} heading="订阅最新文章" /> : null}
</BaseLayout>
